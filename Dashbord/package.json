{
  "name": "atelier-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack --port 3001",
    "build": "next build",
    "postinstall": "node postinstall.js",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "cd ../packages/database && npx prisma generate",
    "db:push": "cd ../packages/database && npx prisma db push",
    "db:migrate": "cd ../packages/database && npx prisma migrate dev",
    "db:seed": "cd ../packages/database && npx tsx prisma/seed.ts",
    "db:studio": "cd ../packages/database && npx prisma studio"
  },
  "dependencies": {
    "@dod/database": "*",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.4.1",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.6.0",
    "framer-motion": "^12.41.0",
    "gsap": "^3.15.0",
    "jose": "^6.0.11",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.80.0",
    "react-icons": "^5.6.0",
    "recharts": "^3.9.0",
    "sass": "^1.101.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/recharts": "^1.8.29",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.4.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "lightningcss-linux-x64-gnu": "1.32.0",
    "lightningcss-linux-x64-musl": "1.32.0",
    "@tailwindcss/oxide-linux-x64-gnu": "4.3.1",
    "@tailwindcss/oxide-linux-x64-musl": "4.3.1"
  }
}
