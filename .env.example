# Auth — MUST change in production (32+ characters)
JWT_SECRET="your-super-secret-jwt-key-at-least-32-bytes-long"
JWT_EXPIRY="7d"

# Cloudinary (admin image uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
